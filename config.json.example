{
    "_note": "Copy this to config.json and fill in api_id/api_hash from https://my.telegram.org",

    "tdjson_path": "~/td/tdlib/lib/libtdjson.so",
    "api_id": 12345678,
    "api_hash": "your_api_hash_here",
    "debug": false,

    "ai": {
        "default_model": "gpt-5.4",
        "models": {
            "openai": [
                "gpt-5.4",
                "gpt-5.4-mini",
                "gpt-5.4-nano",
                "gpt-5.4-pro",
                "gpt-5",
                "gpt-5-mini",
                "gpt-5-nano",
                "gpt-5-pro",
                "gpt-5.3-codex",
                "gpt-5-codex"
            ],
            "gemini": [
                "gemini-3.1-pro-preview",
                "gemini-3-flash-preview",
                "gemini-3.1-flash-lite-preview",
                "gemini-2.5-pro",
                "gemini-2.5-flash",
                "gemini-2.5-flash-lite"
            ]
        }
    },

    "rules": [
        {"match": "exact",  "keyword": "테스트", "action": "reply", "text": "test done"},

        {"match": "suffix", "keyword": "to en", "action": "translate", "lang": "English"},
        {"match": "suffix", "keyword": "to jp", "action": "translate", "lang": "Japanese"},
        {"match": "suffix", "keyword": "to cn", "action": "translate", "lang": "Chinese (Simplified)"},
        {"match": "suffix", "keyword": "to kr", "action": "translate", "lang": "Korean"},

        {"match": "suffix", "keyword": "to ai",  "action": "ask_ai"},
        {"match": "suffix", "keyword": "to web", "action": "ask_ai", "search": true},

        {"match": "prefix", "keyword": "ai model to ", "action": "set_model"}
    ]
}
